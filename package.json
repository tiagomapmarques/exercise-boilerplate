{
  "name": "exercise-boilerplate",
  "version": "0.14.2",
  "license": "MIT",
  "engines": {
    "node": "^26.3.0 || ^24.16.0",
    "pnpm": "^11.5.1"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm"
    }
  },
  "scripts": {
    "postinstall": "playwright install --with-deps && pnpm run licenses && tsr generate && ./bin/env-file.mjs",
    "start": "vite",
    "build": "vite build",
    "serve": "node ./server.mjs",
    "build:watch": "(pnpm build --watch &) && pnpm serve",
    "i18n": "lingui extract --clean && lingui compile --typescript --strict",
    "test": "vitest --run --bail=1",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:watch": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "lint": "biome check --write --error-on-warnings",
    "lint:rewrite": "biome migrate --write && ./bin/biome-file.mjs",
    "licenses": "pnpm licenses ls --prod --json > licenses.prod.json && pnpm licenses ls --json > licenses.json",
    "dependencies": "taze major --interactive --write --install",
    "dependencies:update": "taze minor --write --install && pnpm lint:rewrite && pnpm dependencies:rewrite",
    "dependencies:rewrite": "rimraf ./pnpm-lock.yaml node_modules && pnpm install",
    "check": "pnpm check:project && pnpm check:runtime && pnpm check:other",
    "check:ci": "pnpm install && pnpm check:project && pnpm check:runtime && ./bin/check-engines.mjs && ./bin/uncommitted-changes.mjs --error-on-warnings",
    "check:project": "pnpm dedupe --check && knip && dpdm --no-warning --no-tree ./**/*",
    "check:runtime": "pnpm i18n && pnpm lint && pnpm typecheck && pnpm build && pnpm test && pnpm test:e2e",
    "check:other": "./bin/taze-major-only.mjs && ./bin/check-engines.mjs && ./bin/uncommitted-changes.mjs && pnpm audit",
    "docker:build": "docker build -t exercise-boilerplate-app --progress=plain .",
    "docker:run": "docker run -p 8080:8080 --rm -it --name exercise-boilerplate-app-container exercise-boilerplate-app",
    "docker:ci": "pnpm docker:ci:build && pnpm docker:ci:copy && pnpm docker:ci:clean",
    "docker:ci:build": "docker build -t exercise-boilerplate-ci -f Dockerfile.ci --progress=plain . && docker container create --name exercise-boilerplate-ci-container exercise-boilerplate-ci",
    "docker:ci:copy": "docker cp exercise-boilerplate-ci-container:/reports .",
    "docker:ci:clean": "docker rm exercise-boilerplate-ci-container && docker image rm exercise-boilerplate-ci"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/static": "^9.1.3",
    "@lingui/core": "^6.2.0",
    "@lingui/detect-locale": "^6.2.0",
    "@lingui/react": "^6.2.0",
    "@lingui/swc-plugin": "^6.3.0",
    "@lingui/vite-plugin": "^6.2.0",
    "@mantine/core": "^9.2.2",
    "@mantine/nprogress": "^9.2.2",
    "@tanstack/react-router": "^1.170.10",
    "@tanstack/router-plugin": "^1.168.13",
    "@vitejs/plugin-legacy": "^8.0.2",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "country-flag-icons": "^1.6.17",
    "fastify": "^5.8.5",
    "lucide-react": "^1.17.0",
    "postcss-preset-mantine": "^1.18.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "vite": "^8.0.16",
    "vite-plugin-static-copy": "^4.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@lingui/cli": "^6.2.0",
    "@lingui/format-po": "^6.2.0",
    "@tanstack/devtools-vite": "^0.7.0",
    "@tanstack/react-devtools": "^0.10.5",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/router-cli": "^1.167.12",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-istanbul": "^4.1.8",
    "ajv": "^8.20.0",
    "dpdm": "^4.2.0",
    "knip": "^6.15.0",
    "node-html-parser": "^7.1.0",
    "playwright": "^1.60.0",
    "rimraf": "^6.1.3",
    "taze": "^19.14.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
