{
  "name": "exercise-boilerplate",
  "version": "0.10.4",
  "license": "MIT",
  "engines": {
    "node": "^25.9.0 || ^24.14.1",
    "pnpm": "^10.33.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm"
    }
  },
  "engineStrict": true,
  "scripts": {
    "postinstall": "playwright install --with-deps && pnpm run licenses && tsr generate && ./bin/env-file.mjs",
    "start": "vite",
    "build": "vite build",
    "serve": "node ./server.mjs",
    "build:watch": "(pnpm build --watch &) && pnpm serve",
    "i18n": "lingui extract --clean && lingui compile --typescript --strict",
    "test": "vitest --run --bail=1",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check --write --error-on-warnings",
    "lint:rewrite": "biome migrate --write && ./bin/biome-file.mjs",
    "licenses": "pnpm licenses ls --prod --json > licenses.json && pnpm licenses ls --dev --json > licenses.dev.json",
    "dependencies": "taze major --maturity-period 3 --include-locked --peer --exclude \"@swc/core\" --interactive --write --install",
    "dependencies:rewrite": "rimraf ./pnpm-lock.yaml && git clean -fdx -e .env -e TODO ; pnpm install --ignore-scripts",
    "check": "pnpm check:project && pnpm check:runtime && pnpm check:other",
    "check:ci": "pnpm install && pnpm check:project && pnpm check:runtime && ./bin/check-engines.mjs && ./bin/uncommitted-changes.mjs --error-on-warnings",
    "check:project": "pnpm dedupe --check && knip && dpdm --no-warning --no-tree ./**/*",
    "check:runtime": "pnpm i18n && pnpm lint && pnpm typecheck && pnpm build && pnpm test",
    "check:other": "taze major --maturity-period 3 --include-locked --peer --exclude \"@swc/core\" && ./bin/check-engines.mjs && ./bin/uncommitted-changes.mjs && pnpm audit",
    "docker:build": "docker build -t exercise-boilerplate-app .",
    "docker:run": "docker run -p 8080:8080 --rm -it --name exercise-boilerplate-app-container exercise-boilerplate-app",
    "docker:ci": "pnpm docker:ci:build && pnpm docker:ci:copy && pnpm docker:ci:clean",
    "docker:ci:build": "docker build -t exercise-boilerplate-ci -f Dockerfile.ci . && docker container create --name exercise-boilerplate-ci-container exercise-boilerplate-ci",
    "docker:ci:copy": "docker cp exercise-boilerplate-ci-container:/reports .",
    "docker:ci:clean": "docker rm exercise-boilerplate-ci-container && docker image rm exercise-boilerplate-ci"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/static": "^9.0.0",
    "@lingui/cli": "^5.9.4",
    "@lingui/core": "^5.9.4",
    "@lingui/detect-locale": "^5.9.4",
    "@lingui/format-po": "^5.9.4",
    "@lingui/react": "^5.9.4",
    "@lingui/swc-plugin": "^5.11.0",
    "@lingui/vite-plugin": "^5.9.4",
    "@mantine/core": "^9.0.0",
    "@mantine/nprogress": "^9.0.0",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/router-plugin": "^1.167.12",
    "@vitejs/plugin-legacy": "^8.0.1",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "country-flag-icons": "^1.6.15",
    "fastify": "^5.8.4",
    "lucide-react": "^1.7.0",
    "postcss-preset-mantine": "^1.18.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^8.0.3",
    "vite-plugin-static-copy": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@tanstack/devtools-vite": "^0.6.0",
    "@tanstack/react-devtools": "^0.10.1",
    "@tanstack/react-router-devtools": "^1.166.11",
    "@tanstack/router-cli": "^1.166.25",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-istanbul": "^4.1.2",
    "ajv": "^8.18.0",
    "dpdm": "^4.0.1",
    "knip": "^6.3.0",
    "node-html-parser": "^7.1.0",
    "playwright": "^1.59.1",
    "rimraf": "^6.1.3",
    "taze": "^19.11.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "resolutions": {
    "@swc/core": "1.15.5"
  },
  "pnpm": {}
}
