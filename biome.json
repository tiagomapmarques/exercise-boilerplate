{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**/*",
      "!**/Thumbs.db",
      "!**/.DS_Store",
      "!**/node_modules",
      "!**/node-compile-cache",
      "!**/.pnpm-store",
      "!**/licenses.*json",
      "!**/.tanstack",
      "!**/*.gen.ts",
      "!**/.tmp",
      "!**/dist",
      "!**/coverage",
      "!**/reports",
      "!**/__screenshots__",
      "!**/.vitest-attachments",
      "!**/playwright-report",
      "!**/test-results",
      "!**/.idea",
      "!**/.vscode",
      "!**/.zed",
      "!**/.env",
      "!**/DEVELOPER.md",
      "!**/TODO"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "domains": {
      "playwright": "all",
      "project": "all",
      "react": "all",
      "test": "all",
      "types": "all"
    },
    "rules": {
      "a11y": {
        "noNoninteractiveElementInteractions": "warn"
      },
      "complexity": {
        "noDivRegex": "warn",
        "noExcessiveCognitiveComplexity": "warn",
        "noExcessiveLinesPerFunction": {
          "level": "warn",
          "options": {
            "maxLines": 100,
            "skipBlankLines": true
          }
        },
        "noExcessiveNestedTestSuites": "warn",
        "noExtraBooleanCast": "warn",
        "noFlatMapIdentity": "warn",
        "noForEach": "warn",
        "noImplicitCoercions": "warn",
        "noRedundantDefaultExport": "warn",
        "noUselessCatch": "warn",
        "noUselessCatchBinding": "warn",
        "noUselessConstructor": "warn",
        "noUselessContinue": "warn",
        "noUselessEmptyExport": "warn",
        "noUselessEscapeInRegex": "warn",
        "noUselessFragments": "warn",
        "noUselessLabel": "warn",
        "noUselessLoneBlockStatements": "warn",
        "noUselessRename": "warn",
        "noUselessReturn": "warn",
        "noUselessStringConcat": "warn",
        "noUselessStringRaw": "warn",
        "noUselessSwitchCase": "warn",
        "noUselessTernary": "warn",
        "noUselessThisAlias": "warn",
        "noUselessTypeConstraint": "warn",
        "noUselessUndefined": "warn",
        "noUselessUndefinedInitialization": "warn",
        "noVoid": "warn",
        "useArrayFind": "warn",
        "useFlatMap": "warn",
        "useIndexOf": "warn",
        "useLiteralKeys": "warn",
        "useMaxParams": "warn",
        "useSimplifiedLogicExpression": "warn",
        "useWhile": "warn"
      },
      "correctness": {
        "noGlobalDirnameFilename": "warn",
        "noNodejsModules": "warn",
        "noProcessGlobal": "off",
        "noReactPropAssignments": "warn",
        "noRestrictedElements": "warn",
        "noUndeclaredVariables": "error",
        "noUnresolvedImports": "off",
        "noUnusedInstantiation": "error",
        "useImportExtensions": "off",
        "useJsonImportAttributes": "warn",
        "useParseIntRadix": "warn",
        "useSingleJsDocAsterisk": "warn",
        "useUniqueElementIds": {
          "level": "error",
          "options": {
            "excludedComponents": ["Trans", "Plural"]
          }
        }
      },
      "performance": {
        "noAwaitInLoops": "warn",
        "noBarrelFile": "off",
        "noDelete": "warn",
        "noJsxPropsBind": "off",
        "noNamespaceImport": "warn",
        "noReExportAll": "off",
        "useTopLevelRegex": "warn"
      },
      "security": {
        "noSecrets": "warn"
      },
      "style": {
        "noCommonJs": "warn",
        "noContinue": "warn",
        "noDefaultExport": "warn",
        "noDoneCallback": "warn",
        "noEnum": "warn",
        "noExcessiveClassesPerFile": "warn",
        "noExcessiveLinesPerFile": "warn",
        "noExportedImports": "warn",
        "noHexColors": "warn",
        "noImplicitBoolean": "off",
        "noIncrementDecrement": "warn",
        "noInferrableTypes": "warn",
        "noJsxLiterals": "warn",
        "noMagicNumbers": "warn",
        "noMultiAssign": "warn",
        "noMultilineString": "warn",
        "noNamespace": "warn",
        "noNegationElse": "warn",
        "noNestedTernary": "warn",
        "noParameterAssign": "warn",
        "noParameterProperties": "warn",
        "noProcessEnv": "warn",
        "noRestrictedGlobals": "warn",
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "node:console": {},
              "console": {},
              "@lingui/core": {
                "allowImportNames": [
                  "I18n",
                  "MessageDescriptor",
                  "Messages",
                  "setupI18n"
                ]
              },
              "@testing-library/react": {},
              "vitest": {},
              "vitest/browser": {}
            },
            "patterns": [
              {
                "group": ["@/*/*/*"]
              },
              {
                "group": ["../**"]
              }
            ]
          }
        },
        "noRestrictedTypes": "warn",
        "noRootType": "warn",
        "noShoutyConstants": "warn",
        "noSubstr": "warn",
        "noTernary": "off",
        "noUnusedTemplateLiteral": "warn",
        "noUselessElse": "warn",
        "noValueAtRule": "warn",
        "noYodaExpression": "warn",
        "useArrayLiterals": "warn",
        "useAsConstAssertion": "warn",
        "useAtIndex": "warn",
        "useBlockStatements": "warn",
        "useCollapsedElseIf": "warn",
        "useCollapsedIf": "warn",
        "useConsistentArrayType": "warn",
        "useConsistentArrowReturn": "off",
        "useConsistentBuiltinInstantiation": "warn",
        "useConsistentCurlyBraces": "warn",
        "useConsistentEnumValueType": "warn",
        "useConsistentGraphqlDescriptions": "warn",
        "useConsistentMemberAccessibility": {
          "level": "error",
          "options": {
            "accessibility": "explicit"
          }
        },
        "useConsistentMethodSignatures": "warn",
        "useConsistentObjectDefinitions": "warn",
        "useConsistentTypeDefinitions": {
          "level": "error",
          "options": {
            "style": "type"
          }
        },
        "useDefaultParameterLast": "warn",
        "useDefaultSwitchClause": "warn",
        "useDestructuring": "warn",
        "useEnumInitializers": "warn",
        "useErrorCause": "warn",
        "useExplicitLengthCheck": "warn",
        "useExponentiationOperator": "warn",
        "useExportsLast": "off",
        "useFilenamingConvention": {
          "level": "error",
          "options": {
            "filenameCases": ["kebab-case"]
          }
        },
        "useForOf": "warn",
        "useFragmentSyntax": "warn",
        "useGlobalThis": "warn",
        "useGraphqlNamingConvention": "warn",
        "useGroupedAccessorPairs": "warn",
        "useInputName": "warn",
        "useLoneExecutableDefinition": "warn",
        "useNamingConvention": "warn",
        "useNodeAssertStrict": "warn",
        "useNodejsImportProtocol": "warn",
        "useNumberNamespace": "warn",
        "useNumericSeparators": "warn",
        "useObjectSpread": "warn",
        "useReactFunctionComponents": "warn",
        "useReadonlyClassProperties": "warn",
        "useSelfClosingElements": "warn",
        "useShorthandAssign": "warn",
        "useShorthandFunctionType": "warn",
        "useSingleVarDeclarator": "warn",
        "useSpreadOverApply": "warn",
        "useSymbolDescription": "warn",
        "useTemplate": "warn",
        "useThrowNewError": "warn",
        "useThrowOnlyError": "warn",
        "useTrimStartEnd": "warn",
        "useUnifiedTypeSignatures": "warn"
      },
      "suspicious": {
        "noAlert": "warn",
        "noBitwiseOperators": "warn",
        "noConsole": "warn",
        "noConstantBinaryExpressions": "warn",
        "noDuplicateDependencies": "warn",
        "noDuplicateFields": "warn",
        "noDuplicateGraphqlOperationName": "warn",
        "noDuplicateProperties": "off",
        "noEmptyBlockStatements": "warn",
        "noEmptySource": "warn",
        "noEqualsToNull": "warn",
        "noEvolvingTypes": "warn",
        "noForIn": "warn",
        "noMisplacedAssertion": "warn",
        "noNestedPromises": "warn",
        "noParametersOnlyUsedInRecursion": "warn",
        "noQuickfixBiome": "warn",
        "noReturnAssign": "error",
        "noShadow": "warn",
        "noUnassignedVariables": "warn",
        "noUnknownAtRules": "off",
        "noUnusedExpressions": "warn",
        "noVar": "warn",
        "useAwait": "warn",
        "useDeprecatedDate": "warn",
        "useErrorMessage": "warn",
        "useGuardForIn": "warn",
        "useNumberToFixedDigitsArgument": "warn",
        "useRequiredScripts": "warn",
        "useStaticResponseMethods": "warn",
        "useStrictMode": "warn"
      },
      "nursery": {
        "noBaseToString": "warn",
        "noComponentHookFactories": "error",
        "noConditionalExpect": "warn",
        "noDuplicateFieldDefinitionNames": "warn",
        "noDuplicateSelectors": "warn",
        "noEmptyObjectKeys": "warn",
        "noExcessiveNestedCallbacks": "warn",
        "noExcessiveSelectorClasses": "warn",
        "noFloatingPromises": "warn",
        "noIdenticalTestTitle": "warn",
        "noInlineStyles": "warn",
        "noJsxLeakedDollar": "warn",
        "noJsxNamespace": "warn",
        "noLoopFunc": "warn",
        "noMisleadingReturnType": "warn",
        "noMisusedPromises": "warn",
        "noPlaywrightElementHandle": "warn",
        "noPlaywrightEval": "warn",
        "noPlaywrightForceOption": "warn",
        "noPlaywrightMissingAwait": "warn",
        "noPlaywrightNetworkidle": "warn",
        "noPlaywrightPagePause": "warn",
        "noPlaywrightUselessAwait": "warn",
        "noPlaywrightWaitForNavigation": "warn",
        "noPlaywrightWaitForSelector": "warn",
        "noPlaywrightWaitForTimeout": "warn",
        "noReactStringRefs": "warn",
        "noRestrictedDependencies": "warn",
        "noTopLevelLiterals": "warn",
        "noUndeclaredClasses": "warn",
        "noUnnecessaryTemplateExpression": "warn",
        "noUnsafePlusOperands": "warn",
        "noUntrustedLicenses": "warn",
        "noUnusedClasses": "off",
        "noUselessTypeConversion": "warn",
        "useArraySome": "warn",
        "useAwaitThenable": "warn",
        "useBaseline": "warn",
        "useConsistentTestIt": "warn",
        "useDisposables": "warn",
        "useDomNodeTextContent": "warn",
        "useDomQuerySelector": "warn",
        "useExhaustiveSwitchCases": "warn",
        "useExpect": "warn",
        "useExplicitReturnType": "off",
        "useExplicitType": "off",
        "useIframeSandbox": "warn",
        "useImportsFirst": "warn",
        "useIncludes": "warn",
        "useNamedCaptureGroup": "warn",
        "useNullishCoalescing": "warn",
        "usePlaywrightValidDescribeCallback": "warn",
        "useReactAsyncServerFunction": "warn",
        "useReactFunctionComponentDefinition": {
          "level": "warn",
          "options": {
            "namedComponents": "arrowFunction"
          }
        },
        "useReduceTypeParameter": "warn",
        "useRegexpExec": "warn",
        "useRegexpTest": "warn",
        "useSortedClasses": "warn",
        "useStringStartsEndsWith": "warn",
        "useTestHooksInOrder": "warn",
        "useTestHooksOnTop": "warn",
        "useThisInClassMethods": "warn",
        "useUnicodeRegex": "warn",
        "useVarsOnTop": "warn"
      }
    }
  },
  "javascript": {
    "globals": ["vi"],
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "html": {
    "formatter": {
      "enabled": true
    }
  },
  "css": {
    "formatter": {
      "enabled": true
    }
  },
  "json": {
    "formatter": {
      "enabled": true
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              ":NODE:",
              "react",
              "react-dom",
              "react-dom/client",
              ":PACKAGE:",
              ":BLANK_LINE:",
              "@/testing",
              "@/testing/*",
              "@/providers/*",
              "@/containers/*",
              "@/components/*",
              "@/services/*",
              "@/utilities/*",
              "@/locales/*",
              ":ALIAS:",
              ":BLANK_LINE:",
              ":PATH:",
              "*.css"
            ]
          }
        }
      }
    }
  },
  "overrides": [
    {
      "includes": ["bin/**/*", "**/*.config.*"],
      "linter": {
        "rules": {
          "correctness": {
            "noNodejsModules": "off"
          },
          "style": {
            "noProcessEnv": "off"
          }
        }
      }
    },
    {
      "includes": ["src/components/dev-tools/**/*"],
      "linter": {
        "rules": {
          "style": {
            "noJsxLiterals": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.test.*", "src/testing/**/*"],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveLinesPerFunction": "off"
          },
          "correctness": {
            "useUniqueElementIds": "off"
          },
          "performance": {
            "useTopLevelRegex": "off"
          },
          "style": {
            "noJsxLiterals": "off",
            "noMagicNumbers": "off"
          },
          "nursery": {
            "noComponentHookFactories": "off",
            "useNamedCaptureGroup": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.spec.*"],
      "linter": {
        "rules": {
          "style": {
            "noMagicNumbers": "off"
          },
          "nursery": {
            "useConsistentTestIt": {
              "level": "error",
              "options": {
                "function": "test"
              }
            }
          }
        }
      }
    }
  ]
}
