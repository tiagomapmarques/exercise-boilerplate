{
  "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**/*",
      "!**/Thumbs.db",
      "!**/.DS_Store",
      "!**/node_modules",
      "!**/node-compile-cache",
      "!**/licenses.*json",
      "!**/.tanstack",
      "!**/*.gen.ts",
      "!**/.tmp",
      "!**/dist",
      "!**/coverage",
      "!**/reports",
      "!**/__screenshots__",
      "!**/.vitest-attachments",
      "!**/.idea",
      "!**/.vscode",
      "!**/.zed",
      "!**/.env",
      "!**/TODO"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "domains": {
      "project": "all"
    },
    "rules": {
      "a11y": {
        "recommended": true,
        "noNoninteractiveElementInteractions": "error"
      },
      "complexity": {
        "recommended": true,
        "noExcessiveCognitiveComplexity": "error",
        "noExcessiveLinesPerFunction": "off",
        "noExcessiveNestedTestSuites": "error",
        "noForEach": "error",
        "noImplicitCoercions": "error",
        "noUselessCatchBinding": "error",
        "noUselessStringConcat": "error",
        "noUselessUndefined": "error",
        "noVoid": "error",
        "useMaxParams": "error",
        "useSimplifiedLogicExpression": "error",
        "useWhile": "error"
      },
      "correctness": {
        "recommended": true,
        "noGlobalDirnameFilename": "error",
        "noNestedComponentDefinitions": "error",
        "noNextAsyncClientComponent": "off",
        "noNodejsModules": "off",
        "noProcessGlobal": "off",
        "noReactPropAssignments": "error",
        "noRestrictedElements": "error",
        "noSolidDestructuredProps": "off",
        "noUndeclaredDependencies": "error",
        "noUndeclaredVariables": "error",
        "noUnresolvedImports": "off",
        "noVueSetupPropsReactivityLoss": "off",
        "useImportExtensions": "off",
        "useJsonImportAttributes": "error",
        "useSingleJsDocAsterisk": "error",
        "useUniqueElementIds": {
          "level": "error",
          "options": {
            "excludedComponents": ["Trans", "Plural"]
          }
        },
        "noQwikUseVisibleTask": "off",
        "useQwikClasslist": "off",
        "noVueDataObjectDeclaration": "off",
        "noVueDuplicateKeys": "off",
        "noVueReservedKeys": "off",
        "noVueReservedProps": "off",
        "useQwikMethodUsage": "off",
        "useQwikValidLexicalScope": "off"
      },
      "performance": {
        "recommended": true,
        "noAwaitInLoops": "error",
        "noBarrelFile": "off",
        "noDelete": "error",
        "noNamespaceImport": "error",
        "noReExportAll": "off",
        "useSolidForComponent": "off",
        "useTopLevelRegex": "off"
      },
      "security": {
        "recommended": true,
        "noSecrets": "error"
      },
      "style": {
        "recommended": true,
        "noCommonJs": "error",
        "noDefaultExport": "error",
        "noDoneCallback": "error",
        "noEnum": "error",
        "noExportedImports": "error",
        "noImplicitBoolean": "off",
        "noInferrableTypes": "error",
        "noJsxLiterals": "off",
        "noMagicNumbers": "error",
        "noNamespace": "error",
        "noNegationElse": "error",
        "noNestedTernary": "error",
        "noParameterAssign": "error",
        "noParameterProperties": "error",
        "noProcessEnv": "error",
        "noRestrictedGlobals": "error",
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "node:console": {},
              "console": {},
              "@lingui/core": {
                "allowImportNames": ["I18n", "Messages", "setupI18n"]
              },
              "@testing-library/react": {},
              "vitest": {},
              "vitest/browser": {}
            },
            "patterns": [
              {
                "group": ["@/*/*/*"]
              },
              {
                "group": ["../**"]
              }
            ]
          }
        },
        "noRestrictedTypes": "error",
        "noShoutyConstants": "error",
        "noSubstr": "error",
        "noUnusedTemplateLiteral": "error",
        "noUselessElse": "error",
        "noYodaExpression": "error",
        "useAsConstAssertion": "error",
        "useAtIndex": "error",
        "useBlockStatements": "error",
        "useCollapsedElseIf": "error",
        "useCollapsedIf": "error",
        "useComponentExportOnlyModules": "error",
        "useConsistentArrayType": "error",
        "useConsistentArrowReturn": "off",
        "useConsistentBuiltinInstantiation": "error",
        "useConsistentCurlyBraces": "error",
        "useConsistentMemberAccessibility": {
          "level": "error",
          "options": {
            "accessibility": "explicit"
          }
        },
        "useConsistentObjectDefinitions": "error",
        "useConsistentTypeDefinitions": {
          "level": "warn",
          "options": {
            "style": "type"
          }
        },
        "useDefaultParameterLast": "error",
        "useDefaultSwitchClause": "error",
        "useEnumInitializers": "error",
        "useExplicitLengthCheck": "error",
        "useExportsLast": "off",
        "useFilenamingConvention": {
          "level": "error",
          "options": {
            "filenameCases": ["kebab-case"]
          }
        },
        "useForOf": "error",
        "useFragmentSyntax": "error",
        "useGroupedAccessorPairs": "error",
        "useNamingConvention": "error",
        "useNodeAssertStrict": "error",
        "useNumberNamespace": "error",
        "useNumericSeparators": "error",
        "useObjectSpread": "error",
        "useReactFunctionComponents": "error",
        "useReadonlyClassProperties": "error",
        "useSelfClosingElements": "error",
        "useShorthandAssign": "error",
        "useSingleVarDeclarator": "error",
        "useSymbolDescription": "error",
        "useThrowNewError": "error",
        "useThrowOnlyError": "error",
        "useTrimStartEnd": "error",
        "useUnifiedTypeSignatures": "error"
      },
      "suspicious": {
        "recommended": true,
        "noAlert": "warn",
        "noBitwiseOperators": "warn",
        "noConsole": "warn",
        "noConstantBinaryExpressions": "warn",
        "noDeprecatedImports": "warn",
        "noEmptyBlockStatements": "warn",
        "noEmptySource": "warn",
        "noEvolvingTypes": "warn",
        "noImportCycles": "warn",
        "noMisplacedAssertion": "warn",
        "noReactForwardRef": "warn",
        "noSkippedTests": "warn",
        "noUnassignedVariables": "warn",
        "noUnusedExpressions": "warn",
        "noVar": "warn",
        "useAwait": "warn",
        "useErrorMessage": "warn",
        "useGuardForIn": "warn",
        "useNumberToFixedDigitsArgument": "warn",
        "useStaticResponseMethods": "warn",
        "useStrictMode": "warn",
        "noDuplicateProperties": "off",
        "noUnknownAtRules": "off"
      },
      "nursery": {
        "recommended": true,
        "noAmbiguousAnchorText": "warn",
        "noBeforeInteractiveScriptOutsideDocument": "warn",
        "noComponentHookFactories": "warn",
        "noConditionalExpect": "warn",
        "noContinue": "warn",
        "noDivRegex": "warn",
        "noDrizzleDeleteWithoutWhere": "warn",
        "noDrizzleUpdateWithoutWhere": "warn",
        "noDuplicateEnumValues": "warn",
        "noDuplicatedSpreadProps": "warn",
        "noEqualsToNull": "warn",
        "noExcessiveClassesPerFile": "warn",
        "noExcessiveLinesPerFile": "warn",
        "noExcessiveNestedCallbacks": "warn",
        "noFloatingClasses": "warn",
        "noFloatingPromises": "warn",
        "noForIn": "warn",
        "noIdenticalTestTitle": "warn",
        "noImpliedEval": "warn",
        "noIncrementDecrement": "warn",
        "noInlineStyles": "warn",
        "noJsxLeakedDollar": "warn",
        "noJsxNamespace": "warn",
        "noJsxPropsBind": "off",
        "noLeakedRender": "warn",
        "noLoopFunc": "warn",
        "noMisleadingReturnType": "warn",
        "noMisusedPromises": "warn",
        "noMultiAssign": "warn",
        "noMultiStr": "warn",
        "noNestedPromises": "warn",
        "noParametersOnlyUsedInRecursion": "warn",
        "noPlaywrightElementHandle": "warn",
        "noPlaywrightEval": "warn",
        "noPlaywrightForceOption": "warn",
        "noPlaywrightMissingAwait": "off",
        "noPlaywrightNetworkidle": "warn",
        "noPlaywrightPagePause": "warn",
        "noPlaywrightUselessAwait": "warn",
        "noPlaywrightWaitForNavigation": "warn",
        "noPlaywrightWaitForSelector": "warn",
        "noPlaywrightWaitForTimeout": "warn",
        "noProto": "warn",
        "noReactNativeDeepImports": "off",
        "noReactNativeLiteralColors": "off",
        "noReactNativeRawText": "off",
        "noReactStringRefs": "warn",
        "noRedundantDefaultExport": "warn",
        "noReturnAssign": "warn",
        "noScriptUrl": "warn",
        "noShadow": "warn",
        "noSyncScripts": "warn",
        "noTernary": "off",
        "noUndeclaredEnvVars": "warn",
        "noUnknownAttribute": "warn",
        "noUnnecessaryConditions": "warn",
        "noUnnecessaryTemplateExpression": "warn",
        "noUnsafePlusOperands": "warn",
        "noUselessReturn": "warn",
        "noUselessTypeConversion": "warn",
        "noVueArrowFuncInWatch": "off",
        "noVueOptionsApi": "off",
        "noVueRefAsOperand": "off",
        "useArraySome": "warn",
        "useArraySortCompare": "warn",
        "useAwaitThenable": "warn",
        "useConsistentEnumValueType": "warn",
        "useConsistentMethodSignatures": "warn",
        "useConsistentTestIt": "warn",
        "useDestructuring": "warn",
        "useDisposables": "warn",
        "useDomNodeTextContent": "warn",
        "useDomQuerySelector": "warn",
        "useErrorCause": "warn",
        "useExhaustiveSwitchCases": "warn",
        "useExpect": "warn",
        "useExplicitReturnType": "off",
        "useExplicitType": "off",
        "useFind": "warn",
        "useGlobalThis": "warn",
        "useIframeSandbox": "warn",
        "useImportsFirst": "warn",
        "useInlineScriptId": "warn",
        "useMathMinMax": "warn",
        "useNamedCaptureGroup": "warn",
        "useNullishCoalescing": "warn",
        "usePlaywrightValidDescribeCallback": "warn",
        "useQwikLoaderLocation": "off",
        "useReactAsyncServerFunction": "warn",
        "useReactNativePlatformComponents": "off",
        "useReduceTypeParameter": "warn",
        "useRegexpExec": "warn",
        "useRegexpTest": "warn",
        "useSortedClasses": "off",
        "useSpread": "warn",
        "useStringStartsEndsWith": "warn",
        "useTestHooksOnTop": "warn",
        "useUnicodeRegex": "warn",
        "useVarsOnTop": "warn",
        "useVueConsistentDefinePropsDeclaration": "off",
        "useVueDefineMacrosOrder": "off",
        "useVueMultiWordComponentNames": "off"
      }
    }
  },
  "javascript": {
    "globals": ["vi"],
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "html": {
    "formatter": {
      "enabled": true
    }
  },
  "css": {
    "formatter": {
      "enabled": true
    }
  },
  "json": {
    "formatter": {
      "enabled": true
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              ":NODE:",
              "react",
              "react-dom",
              "react-dom/client",
              ":PACKAGE:",
              ":BLANK_LINE:",
              "@/testing",
              "@/testing/*",
              "@/containers",
              "@/containers/*",
              "@/providers",
              "@/providers/*",
              ":ALIAS:",
              ":BLANK_LINE:",
              ":PATH:",
              "*.css"
            ]
          }
        }
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/*.config.*"],
      "linter": {
        "rules": {
          "style": {
            "useNamingConvention": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.test.*", "**/src/testing/**/*"],
      "linter": {
        "rules": {
          "style": {
            "noMagicNumbers": "off"
          },
          "nursery": {
            "noComponentHookFactories": "off",
            "useNamedCaptureGroup": "off"
          }
        }
      }
    }
  ]
}
